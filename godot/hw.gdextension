[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true

[libraries]
linux.debug.x86_64 =     "res://../rust/target/debug/librbindings.so"
linux.release.x86_64 =   "res://../rust/target/release/librbindings.so"
windows.debug.x86_64 =   "res://../rust/target/debug/rbindings.dll"
windows.release.x86_64 = "res://../rust/target/release/rbindings.dll"
macos.debug =            "res://../rust/target/debug/librbindings.dylib"
macos.release =          "res://../rust/target/release/librbindings.dylib"
macos.debug.arm64 =      "res://../rust/target/debug/librbindings.dylib"
macos.release.arm64 =    "res://../rust/target/release/librbindings.dylib"
web.debug.wasm32 =       "res://../rust/target/wasm32-unknown-emscripten/debug/rbindings.wasm"
web.release.wasm32 =     "res://../rust/target/wasm32-unknown-emscripten/release/rbindings.wasm"
